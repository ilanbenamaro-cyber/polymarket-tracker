{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ilanbenamaro-cyber.github.io/polymarket-tracker/api/v1/schema.json",
  "title": "Polymarket SpaceX-IPO canonical snapshot record",
  "type": "object",
  "required": ["schema_version", "methodology_version", "assumptions_version", "asset", "snapshot"],
  "properties": {
    "schema_version": { "type": "string" },
    "methodology_version": { "type": "string" },
    "assumptions_version": { "type": "string" },
    "asset": {
      "type": "object",
      "required": ["id", "platform", "resolves"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "platform": { "type": "string" },
        "market_url": { "type": "string" },
        "resolves": { "type": "string" }
      }
    },
    "snapshot": {
      "type": "object",
      "required": ["snapshot_id", "fetched_at", "source", "raw_inputs", "derived"],
      "properties": {
        "snapshot_id": { "type": "string" },
        "fetched_at": { "type": "string" },
        "source": {
          "type": "object",
          "required": ["provider", "raw_sha256"],
          "properties": {
            "provider": { "type": "string" },
            "endpoints": { "type": "array", "items": { "type": "string" } },
            "raw_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
          }
        },
        "raw_inputs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["token_id", "threshold", "midpoint"],
            "properties": {
              "token_id": { "type": "string" },
              "threshold": { "type": "number" },
              "midpoint": { "type": "string" },
              "best_bid": { "type": ["string", "null"] },
              "best_ask": { "type": ["string", "null"] },
              "volume": { "type": ["number", "null"] }
            }
          }
        },
        "derived": {
          "type": "object",
          "required": [
            "implied_median", "implied_mean", "mean", "iqr",
            "total_volume", "adjustment", "confidence", "markets",
            "market", "scenarios"
          ],
          "properties": {
            "market": {
              "type": "object",
              "required": ["analytics"],
              "properties": {
                "analytics": {
                  "type": "object",
                  "required": ["shape", "dispersion", "velocity", "calibration", "descriptor"],
                  "properties": {
                    "shape": { "type": "object" },
                    "dispersion": { "type": "object" },
                    "velocity": { "type": "object" },
                    "calibration": {
                      "type": "object",
                      "required": ["status"],
                      "properties": { "status": { "type": "string" } }
                    },
                    "descriptor": { "type": "string" }
                  }
                }
              }
            },
            "scenarios": {
              "type": "object",
              "required": ["assumptions_version", "share_price", "round_over_round"],
              "properties": {
                "assumptions_version": { "type": ["string", "null"] },
                "share_price": { "type": "object" },
                "round_over_round": { "type": "object" }
              }
            },
            "implied_median": { "type": ["number", "null"] },
            "implied_mean": { "type": ["number", "null"] },
            "median": {
              "type": ["object", "null"],
              "required": ["central", "low", "high"],
              "properties": {
                "central": { "type": ["number", "null"] },
                "low": { "type": ["number", "null"] },
                "high": { "type": ["number", "null"] }
              }
            },
            "mean": {
              "type": "object",
              "required": ["central", "low", "high"],
              "properties": {
                "central": { "type": ["number", "null"] },
                "low": { "type": ["number", "null"] },
                "high": { "type": ["number", "null"] }
              }
            },
            "iqr": {
              "type": "object",
              "properties": {
                "p25": { "type": ["number", "null"] },
                "p75": { "type": ["number", "null"] }
              }
            },
            "total_volume": { "type": "number" },
            "adjustment": {
              "type": "object",
              "required": ["monotonicity_violations", "max_adjustment"],
              "properties": {
                "monotonicity_violations": { "type": "integer", "minimum": 0 },
                "max_adjustment": { "type": "number", "minimum": 0 }
              }
            },
            "confidence": {
              "type": "object",
              "required": ["tier", "score", "reasons"],
              "properties": {
                "tier": { "type": "string", "enum": ["high", "medium", "low"] },
                "score": { "type": "number", "minimum": 0, "maximum": 1 },
                "reasons": { "type": "array", "items": { "type": "string" } }
              }
            },
            "markets": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["label", "threshold", "raw_prob", "adjusted_prob", "prob", "bucket_prob"],
                "properties": {
                  "label": { "type": "string" },
                  "threshold": { "type": "number" },
                  "raw_prob": { "type": "number", "minimum": 0, "maximum": 1 },
                  "adjusted_prob": { "type": "number", "minimum": 0, "maximum": 1 },
                  "prob": { "type": "number", "minimum": 0, "maximum": 1 },
                  "bucket_prob": { "type": "number", "minimum": -0.000001, "maximum": 1 },
                  "volume": { "type": ["number", "null"] },
                  "volume_tier": { "type": ["string", "null"], "enum": ["high", "med", "low", null] }
                }
              }
            },
            "narrative": { "type": "string" },
            "narrative_components": { "type": "object" }
          }
        }
      }
    }
  }
}
