# Microsoft Graph (corporate M365 app registration — client-credentials flow)
GRAPH_TENANT_ID=your-tenant-id
GRAPH_CLIENT_ID=your-client-id
GRAPH_CLIENT_SECRET=your-client-secret
MAIL_FROM=sender@yourcompany.com

# Subscriber storage (private Gist with a single file: subscribers.json)
GIST_TOKEN=ghp_your_gist_classic_pat
GIST_ID=your_gist_id_hash

# ── Phase 2a backend (Supabase) ──────────────────────────────────────────────
# Supabase → Project Settings → API. These power the serverless cache function
# (api/market.mjs) and the one-time seed (scripts/seed-spacex.mjs).
#
# SERVER-SIDE ONLY. The service-role key is write-capable and bypasses RLS — it
# must live only in the Vercel function's env (and your local .env for the seed/
# verify scripts). NEVER expose it to the browser; NEVER prefix it NEXT_PUBLIC_.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# Live-verification runner only (scripts/verify-phase2a.mjs) — your Vercel URL.
BASE_URL=https://your-deployment.vercel.app
